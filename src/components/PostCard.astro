---
import type { ImageMetadata } from 'astro';
import type { BlogPost } from '../types';
import { formatDate } from '../utils/content';

// 自动导入 assets 目录下的所有图片
const images = import.meta.glob('../assets/**/*.{jpg,jpeg,png,webp,gif}', { eager: true, import: 'default' });
const defaultCovers = Object.values(images) as ImageMetadata[];

interface Props {
  post: BlogPost;
  variant?: 'default' | 'featured';
}

const { post, variant = 'default' } = Astro.props;
const isFeatured = variant === 'featured';

// 如果没有封面，使用基于文章标题的确定性随机封面
const coverImage = post.cover || (() => {
  if (defaultCovers.length === 0) return null;
  // 使用文章标题作为种子，确保同一篇文章总是得到相同的封面
  let hash = 0;
  const seed = post.title || post.id;
  for (let i = 0; i < seed.length; i++) {
    const char = seed.charCodeAt(i);
    hash = ((hash << 5) - hash) + char;
    hash = hash & hash;
  }
  const index = Math.abs(hash) % defaultCovers.length;
  return defaultCovers[index];
})();
---

<article 
  class={`group relative bg-[var(--color-surface)] rounded-lg overflow-hidden border border-[var(--color-border)] transition-all duration-500 ease-[var(--ease-luxury)] hover:border-[var(--color-border-hover)] flex flex-col h-full ${isFeatured ? 'md:grid md:grid-cols-2 md:gap-0' : ''}`}
  style="transform: translateY(0);"
  onmouseenter="this.style.transform='translateY(-2px)'"
  onmouseleave="this.style.transform='translateY(0)'">
  
  <!-- Cover Image -->
  <div class={`overflow-hidden shrink-0 ${isFeatured ? 'aspect-[4/3] md:aspect-auto md:h-full' : 'aspect-[16/10]'}`}>
    {coverImage ? (
      <a href={`/posts/${post.slug}`} class="block h-full">
        <img
          src={coverImage.src}
          alt={post.title}
          class="w-full h-full object-cover transition-transform duration-700 ease-[var(--ease-luxury)] group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
        {isFeatured && (
          <div class="absolute top-4 left-4 px-3 py-1 text-xs bg-[var(--color-primary)] text-white rounded-full font-medium tracking-wide">
            置顶
          </div>
        )}
      </a>
    ) : (
      <a href={`/posts/${post.slug}`} class="block h-full bg-[var(--color-surface-elevated)] flex items-center justify-center">
        <span class="font-serif text-4xl text-[var(--color-text-subtle)] opacity-30">{post.title.charAt(0)}</span>
      </a>
    )}
  </div>
  
  <!-- Content -->
  <div class={`flex flex-col flex-1 ${isFeatured ? 'p-6 md:p-8 lg:p-10' : 'p-5'}`}>
    <div class="flex items-center gap-3 text-xs text-[var(--color-text-subtle)] mb-3 tracking-wide shrink-0">
      <time datetime={post.publishedAt.toISOString()} class="font-medium">{formatDate(post.publishedAt)}</time>
      {post.category && (
        <>
          <span class="w-1 h-1 rounded-full bg-[var(--color-text-subtle)] opacity-60"></span>
          <a href={`/categories/${post.category.slug}`} class="hover:text-[var(--color-primary-hover)] transition-colors duration-200 truncate max-w-[100px]">
            {post.category.name}
          </a>
        </>
      )}
    </div>
    
    <h3 class={`font-serif font-medium text-[var(--color-text)] group-hover:text-[var(--color-primary-hover)] transition-colors duration-300 leading-snug line-clamp-2 ${isFeatured ? 'text-2xl md:text-3xl mb-4 min-h-[2.5em]' : 'text-lg mb-2 min-h-[2.5em]'}`}>
      <a href={`/posts/${post.slug}`} class="block">
        {post.title}
      </a>
    </h3>
    
    <p class={`text-[var(--color-text-muted)] leading-relaxed line-clamp-2 ${isFeatured ? 'text-base mb-6' : 'text-sm mb-4'}`}>
      {post.description}
    </p>
    
    <div class="mt-auto pt-4 flex items-center gap-2 flex-wrap border-t border-[var(--color-border-subtle)] shrink-0 min-h-[44px]">
      {post.tags.length > 0 ? (
        <>
          {post.tags.slice(0, 3).map(tag => (
            <span class="px-2.5 py-1 text-xs bg-[var(--color-surface-elevated)] rounded text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary-subtle)] transition-all duration-200 cursor-default whitespace-nowrap">
              {tag.name}
            </span>
          ))}
          {post.tags.length > 3 && (
            <span class="text-xs text-[var(--color-text-subtle)]">+{post.tags.length - 3}</span>
          )}
        </>
      ) : (
        <span class="text-xs text-[var(--color-text-subtle)] opacity-50">无标签</span>
      )}
    </div>
  </div>
</article>

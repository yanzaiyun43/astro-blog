---
import { SITE, NAVIGATION } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';

const navItems = [
  { label: '首页', href: NAVIGATION.home },
  { label: '文章', href: NAVIGATION.posts },
  { label: '友链', href: NAVIGATION.friends },
  { label: '关于', href: NAVIGATION.about },
];
---

<header 
  x-data="{ 
    hidden: false, 
    lastScroll: 0,
    mobileOpen: false 
  }"
  x-init="$watch('mobileOpen', value => document.body.classList.toggle('overflow-hidden', value))"
  @scroll.window.throttle.100ms="
    const current = window.pageYOffset;
    hidden = current > lastScroll && current > 100 && !mobileOpen;
    lastScroll = current;
  "
  :class="{ '-translate-y-full': hidden }"
  class="fixed top-0 left-0 right-0 z-50 transition-transform duration-500 ease-[var(--ease-luxury)] bg-[var(--color-bg)]/90 backdrop-blur-md border-b border-[var(--color-border)]">
  
  <nav class="container-luxury h-16 flex items-center justify-between gap-4">
    <!-- Logo -->
    <a href="/" class="font-serif text-lg md:text-xl font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors duration-200 shrink-0">
      {SITE.name}
    </a>
    
    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-6 lg:gap-8">
      {navItems.map(item => (
        <a 
          href={item.href}
          class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors duration-200 relative group py-1">
          {item.label}
          <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-[var(--color-primary)] transition-all duration-300 ease-[var(--ease-luxury)] group-hover:w-full"></span>
        </a>
      ))}
      
      <div class="w-px h-4 bg-[var(--color-border)]"></div>
      
      <Search />
      
      <ThemeToggle />
    </div>
    
    <!-- Mobile Menu Button -->
    <div class="flex items-center gap-2 md:hidden">
      <Search />
      
      <button 
        @click="mobileOpen = !mobileOpen"
        class="p-2 text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors duration-200 rounded-md hover:bg-[var(--color-surface-elevated)]"
        :aria-expanded="mobileOpen"
        aria-label="切换菜单">
        <svg x-show="!mobileOpen" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg x-show="mobileOpen" x-cloak xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </nav>
  
  <!-- Mobile Menu -->
  <div 
    x-show="mobileOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    x-cloak
    class="md:hidden absolute top-16 left-0 right-0 bg-[var(--color-surface)] border-b border-[var(--color-border)] shadow-luxury-hover">
    <div class="container-luxury py-4 space-y-1">
      {navItems.map(item => (
        <a 
          href={item.href}
          @click="mobileOpen = false"
          class="block py-3 text-base text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors duration-200 border-b border-[var(--color-border-subtle)] last:border-0">
          {item.label}
        </a>
      ))}
      
      <div class="pt-4 flex items-center justify-between">
        <span class="text-sm text-[var(--color-text-subtle)]">主题</span>
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

---
import { getCollection } from 'astro:content';
import { filterPublished, sortPosts } from '../utils/content';

const posts = await getCollection('posts');
const published = filterPublished(posts);
const sorted = sortPosts(published);

const searchData = sorted.map(p => ({
  slug: p.id.replace(/\.mdx?$/, '').replace(/\/index$/, ''),
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  tags: p.data.tags,
}));
---

<script is:inline define:vars={{ searchData }}>
  window.__POSTS__ = searchData;
</script>

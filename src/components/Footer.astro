---
import { SITE, SOCIAL_LINKS } from '../consts';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: 'GitHub', href: SOCIAL_LINKS.github, icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>' },
  { name: '邮箱', href: SOCIAL_LINKS.email, icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>' },
  { name: 'RSS订阅', href: SOCIAL_LINKS.rss, icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>' },
  { name: '站点地图', href: SOCIAL_LINKS.sitemap, icon: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 1.892.402 3.13 1.5 4.5L12 22l6.5-7.5c1.098-1.37 1.5-2.608 1.5-4.5a8 8 0 0 0-8-8"/></svg>' },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface-elevated)] mt-auto">
  <div class="container-luxury py-12 md:py-16">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- 品牌信息 -->
      <div class="text-center md:text-left">
        <a href="/" class="font-serif text-lg font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors duration-300">
          {SITE.name}
        </a>
        <p class="text-sm text-[var(--color-text-subtle)] mt-1">{SITE.description}</p>
      </div>
      
      <!-- 社交链接 -->
      <div class="flex items-center gap-4">
        {socialLinks.map(link => (
          <a 
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] transition-all duration-300 hover:-translate-y-0.5 relative group"
            aria-label={link.name}>
            <Fragment set:html={link.icon} />
            <!-- Tooltip -->
            <span class="absolute -top-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-[var(--color-surface)] text-xs text-[var(--color-text)] rounded border border-[var(--color-border)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 whitespace-nowrap shadow-lg">
              {link.name}
              <!-- Arrow -->
              <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-[var(--color-surface)] border-r border-b border-[var(--color-border)] rotate-45"></span>
            </span>
          </a>
        ))}
      </div>
    </div>
    
    <!-- 底部版权栏 -->
    <div class="mt-8 pt-8 border-t border-[var(--color-border-subtle)] flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-[var(--color-text-subtle)]">
      <p class="flex items-center gap-2">
        <span>&copy; {currentYear} {SITE.name}. 保留所有权利。</span>
        <span class="hidden md:inline text-[var(--color-border)]">|</span>
        <span class="flex items-center gap-1" title="从 2025-12-31 开始运行">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span id="run-days">加载中...</span>
        </span>
      </p>
      <p class="flex items-center gap-4">
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span id="visitor-count">加载中...</span>
        </span>
        <span>主题制作 by {SITE.defaultAuthor}</span>
      </p>
    </div>
  </div>
</footer>

<!-- 运行天数计算 -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const runDaysEl = document.getElementById('run-days');
    if (runDaysEl) {
      const startDate = new Date('2025-12-31');
      const runDays = Math.floor((new Date().getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));
      runDaysEl.textContent = '本站稳定运行 ' + runDays + ' 天';
    }
  });
</script>

<!-- 访客统计 -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const countEl = document.getElementById('visitor-count');
    if (!countEl) return;

    // 读取本地存储的访客标识和创建时间
    let visitorId = localStorage.getItem('visitorId');
    let createTime = localStorage.getItem('visitorId_create_time');
    const now = Date.now();
    const thirtyDays = 30 * 24 * 60 * 60 * 1000; // 30 天毫秒数

    // 判断是否需要更新访客标识
    let needNew = !visitorId || !createTime || (now - parseInt(createTime, 10)) > thirtyDays;
    if (needNew) {
      visitorId = Math.random().toString(36).slice(2);
      createTime = now.toString();
      localStorage.setItem('visitorId', visitorId);
      localStorage.setItem('visitorId_create_time', createTime);
    }

    // 请求统计接口
    fetch(`https://ailmel.dpdns.org/visit.php?api=1&visitorId=${visitorId}`)
      .then(res => res.json())
      .then(data => {
        countEl.textContent = '本站已累计访问 ' + data.total + ' 位访客' || '获取失败';
      })
      .catch(err => {
        countEl.textContent = '获取失败';
        console.error('统计接口错误：', err);
      });
  });
</script>

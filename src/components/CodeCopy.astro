---
// 代码复制按钮组件 - 极简样式 + 过渡动画
---

<div class="code-copy-wrapper absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300" x-data="{ copied: false }">
  <button 
    @click="
      const code = $el.closest('pre')?.querySelector('code')?.textContent || '';
      navigator.clipboard.writeText(code).then(() => {
        copied = true;
        setTimeout(() => copied = false, 2000);
      });
    "
    class="p-1.5 rounded-subtle bg-[var(--color-surface)]/80 backdrop-blur-sm border border-[var(--color-border)] text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-all duration-300"
    :class="{ '!text-[var(--color-primary)] !border-[var(--color-primary)]': copied }"
    :aria-label="copied ? '已复制' : '复制代码'">
    
    <!-- Copy Icon -->
    <svg x-show="!copied" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 scale-75" x-transition:enter-end="opacity-100 scale-100" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
    
    <!-- Check Icon -->
    <svg x-show="copied" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 scale-75" x-transition:enter-end="opacity-100 scale-100" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
  </button>
</div>

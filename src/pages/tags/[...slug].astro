---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import TagList from '../../components/TagList.astro';
import { filterPublished, sortPosts, mapToBlogPost, getTags, generateSlug } from '../../utils/content';
import { SITE } from '../../consts';

export const getStaticPaths = (async () => {
  const postsPerPage = 9;
  const posts = await getCollection('posts');
  const published = filterPublished(posts);
  const tags = getTags(published);
  const validTags = tags.filter(tag => tag.slug && tag.slug.trim() !== '');

  const paths = [];

  for (const tag of validTags) {
    const tagPosts = published.filter(post =>
      post.data.tags.some(t => generateSlug(t) === tag.slug)
    );
    const sorted = sortPosts(tagPosts);
    const totalPages = Math.ceil(sorted.length / postsPerPage);

    // 第 1 页: /tags/xxx
    paths.push({
      params: { slug: tag.slug },
      props: { tag, allTags: tags, postsPerPage, currentPage: 1, totalPages, totalPosts: sorted.length },
    });

    // 第 2+ 页: /tags/xxx/2, /tags/xxx/3 ...
    for (let p = 2; p <= totalPages; p++) {
      paths.push({
        params: { slug: `${tag.slug}/${p}` },
        props: { tag, allTags: tags, postsPerPage, currentPage: p, totalPages, totalPosts: sorted.length },
      });
    }
  }

  return paths;
}) satisfies GetStaticPaths;

const { tag, allTags, postsPerPage, currentPage, totalPages, totalPosts } = Astro.props;

const posts = await getCollection('posts');
const published = filterPublished(posts);
const tagPosts = published.filter(post =>
  post.data.tags.some(t => generateSlug(t) === tag.slug)
);
const sorted = sortPosts(tagPosts);
const displayPosts = sorted.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);

const author = {
  id: '1',
  name: SITE.defaultAuthor,
  slug: 'author',
};

const baseUrl = `/tags/${tag.slug}`;
---

<BaseLayout title={currentPage === 1 ? `标签：${tag.name}` : `标签：${tag.name} - 第 ${currentPage} 页`} description={`${tag.name} 标签下的所有文章`} class="pt-16">
  <Navbar slot="header" />

  <div class="container-luxury section-padding pt-24">
    <!-- Tag Header -->
    <div class="text-center mb-12 pb-8 border-b border-[var(--color-border)]">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-gentle bg-[var(--color-primary-subtle)] text-[var(--color-primary)] text-sm mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
        <span>标签</span>
      </div>
      <h1 class="font-serif text-3xl md:text-4xl font-medium mb-3 text-[var(--color-text)]">#{tag.name}</h1>
      <p class="text-[var(--color-text-muted)]">该标签下共有 {totalPosts} 篇文章</p>
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayPosts.map((post, index) => (
        <div class="animate-fade-in-up" style={`animation-delay: ${0.05 * index}s;`}>
          <PostCard post={mapToBlogPost(post, author)} />
        </div>
      ))}
    </div>

    {totalPages > 1 && (
      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        baseUrl={baseUrl}
      />
    )}

    <!-- All Tags -->
    <div class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <h3 class="font-serif text-lg font-medium mb-6 text-[var(--color-text)]">其他标签</h3>
      <TagList tags={allTags.filter(t => t.slug !== tag.slug).slice(0, 12)} />
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

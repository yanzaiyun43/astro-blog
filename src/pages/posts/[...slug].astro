---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { mapToBlogPost, getRelatedPosts, filterPublished, sortPosts } from '../../utils/content';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const slugMap = new Map<string, string>();
  
  const paths = posts.map((post) => {
    const slug = post.data.slug || post.id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
    
    // 检测 slug 冲突
    if (slugMap.has(slug)) {
      console.warn(`[警告] slug 冲突: "${slug}" 被多篇文章使用 (${slugMap.get(slug)} 和 ${post.id})`);
    } else {
      slugMap.set(slug, post.id);
    }
    
    return {
      params: { slug },
      props: post,
    };
  });
  
  return paths;
}

type Props = CollectionEntry<'posts'>;

const post = Astro.props;
const { Content, headings } = await render(post);

// 获取相关文章
const allPosts = await getCollection('posts');
const published = filterPublished(allPosts);
const relatedRaw = getRelatedPosts(post, published, 3);

const author = {
  id: '1',
  name: SITE.defaultAuthor,
  slug: 'author',
};

const relatedPosts = relatedRaw.map(p => mapToBlogPost(p, author));

// 上一篇/下一篇
const sorted = sortPosts(published);
const currentIndex = sorted.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;

const blogPost = mapToBlogPost(post, author);
---

<PostLayout post={blogPost} headings={headings} relatedPosts={relatedPosts}>
  <Navbar slot="header" />
  
  <Content />
  
  <!-- Prev/Next Navigation -->
  <div slot="article-footer" class="mt-12 pt-8 border-t border-[var(--color-border)]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {prevPost ? (
        <a href={`/posts/${prevPost.id.replace(/\.mdx?$/, '').replace(/\/index$/, '')}/`} class="group p-4 border border-[var(--color-border)] rounded-gentle hover:border-[var(--color-primary)] transition-all duration-300">
          <span class="text-xs text-[var(--color-text-subtle)] mb-1 block">上一篇</span>
          <span class="text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors duration-300 line-clamp-2 font-medium">{prevPost.data.title}</span>
        </a>
      ) : <div />}
      
      {nextPost ? (
        <a href={`/posts/${nextPost.id.replace(/\.mdx?$/, '').replace(/\/index$/, '')}/`} class="group p-4 border border-[var(--color-border)] rounded-gentle hover:border-[var(--color-primary)] transition-all duration-300 text-right">
          <span class="text-xs text-[var(--color-text-subtle)] mb-1 block">下一篇</span>
          <span class="text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors duration-300 line-clamp-2 font-medium">{nextPost.data.title}</span>
        </a>
      ) : <div />}
    </div>
  </div>
  
  <Footer slot="footer" />
</PostLayout>

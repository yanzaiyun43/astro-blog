---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import TagList from '../../components/TagList.astro';
import SearchData from '../../components/SearchData.astro';
import { sortPosts, filterPublished, mapToBlogPost, getCategories, getTags } from '../../utils/content';
import { SITE, NAVIGATION, HERO_TYPEWRITER } from '../../consts';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection('posts');
  const published = filterPublished(posts);
  const sorted = sortPosts(published);
  
  return paginate(sorted, { pageSize: 9 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const posts = page.data;

const allPosts = await getCollection('posts');
const published = filterPublished(allPosts);
const categories = getCategories(published);
const tags = getTags(published);

// 置顶文章（最多2篇）- 所有页面都显示
const sortedAll = sortPosts(published);
const featuredPosts = sortedAll.filter(p => p.data.featured).slice(0, 2);

// 当前页的普通文章（排除置顶文章）
const regularPosts = posts.filter(p => !p.data.featured || !featuredPosts.find(fp => fp.id === p.id));

const author = {
  id: '1',
  name: SITE.defaultAuthor,
  slug: 'author',
};

const baseUrl = NAVIGATION.posts;
---

<BaseLayout title={page.currentPage === 1 ? SITE.name : `第 ${page.currentPage} 页 - ${SITE.name}`} description="浏览全部文章存档" class="pt-16">
  <Navbar slot="header" />
  
  <div class="w-full">
    <!-- Hero Section -->
    <section class="border-b border-[var(--color-border)]">
      <div class="container-luxury section-padding text-center max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-medium mb-6 leading-tight animate-fade-in-up" style="animation-delay: 0.1s;">
          {SITE.name}
        </h1>
        <!-- 打字机效果描述 -->
        <div 
          class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed flex items-center justify-center"
          x-data={`{ 
            texts: ${JSON.stringify(HERO_TYPEWRITER.texts)}, 
            currentText: '', 
            textIndex: 0, 
            charIndex: 0, 
            isDeleting: false,
            typeSpeed: ${HERO_TYPEWRITER.typeSpeed},
            deleteSpeed: ${HERO_TYPEWRITER.deleteSpeed},
            pauseTime: ${HERO_TYPEWRITER.pauseTime},
            type() {
              const fullText = this.texts[this.textIndex];
              if (this.isDeleting) {
                this.currentText = fullText.substring(0, this.charIndex - 1);
                this.charIndex--;
              } else {
                this.currentText = fullText.substring(0, this.charIndex + 1);
                this.charIndex++;
              }
              
              let speed = this.isDeleting ? this.deleteSpeed : this.typeSpeed;
              
              if (!this.isDeleting && this.charIndex === fullText.length) {
                speed = this.pauseTime;
                this.isDeleting = true;
              } else if (this.isDeleting && this.charIndex === 0) {
                this.isDeleting = false;
                this.textIndex = (this.textIndex + 1) % this.texts.length;
              }
              
              setTimeout(() => this.type(), speed);
            }
          }`}
          x-init="type()">
          <span x-text="currentText" class="font-light"></span>
          <span class="inline-block w-0.5 h-[1.2em] bg-[var(--color-primary)] ml-0.5 animate-pulse align-middle"></span>
        </div>
        
        <!-- Quick Stats -->
        <div class="flex items-center justify-center gap-8 mt-8 text-sm text-[var(--color-text-subtle)] animate-fade-in-up" style="animation-delay: 0.3s;">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[var(--color-primary)]"></span>
            <span>{published.length} 篇文章</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[var(--color-primary)]"></span>
            <span>{categories.length} 个分类</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[var(--color-primary)]"></span>
            <span>{tags.length} 个标签</span>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Featured Posts -->
    {featuredPosts.length > 0 && (
      <section class="border-b border-[var(--color-border)] bg-[var(--color-surface-elevated)]">
        <div class="container-luxury section-padding">
          <div class="flex items-center gap-3 mb-8">
            <span class="w-8 h-px bg-[var(--color-primary)]"></span>
            <h2 class="font-serif text-xl font-medium text-[var(--color-text)]">置顶文章</h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
            {featuredPosts.map((post, index) => (
              <div class="animate-fade-in-up h-full" style={`animation-delay: ${0.1 * (index + 1)}s;`}>
                <PostCard post={mapToBlogPost(post, author)} variant="featured" />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}
    
    <!-- Main Content -->
    <section class="container-luxury section-padding">
      <div class="flex flex-col lg:flex-row gap-12">
        <!-- Posts Grid -->
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-8">
            <span class="w-8 h-px bg-[var(--color-text-subtle)]"></span>
            <h2 class="font-serif text-xl font-medium text-[var(--color-text)]">最新文章</h2>
            <span class="text-sm text-[var(--color-text-subtle)] ml-auto">
              第 {page.currentPage} / {page.lastPage} 页
            </span>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
            {regularPosts.map((post, index) => (
              <div class="animate-fade-in-up h-full" style={`animation-delay: ${0.05 * index}s;`}>
                <PostCard post={mapToBlogPost(post, author)} />
              </div>
            ))}
          </div>
          
          {page.lastPage > 1 && (
            <div class="mt-12">
              <Pagination 
                currentPage={page.currentPage} 
                totalPages={page.lastPage} 
                baseUrl={baseUrl} 
              />
            </div>
          )}
        </div>
        
        <!-- Sidebar -->
        <aside class="w-full lg:w-72 shrink-0 space-y-8">
          <!-- Categories -->
          <div class="p-6 rounded-subtle border border-[var(--color-border)] bg-[var(--color-surface)]">
            <h3 class="font-serif text-lg font-medium mb-4 text-[var(--color-text)]">分类</h3>
            <div class="space-y-2">
              {categories.slice(0, 8).map(cat => (
                <a 
                  href={`/categories/${cat.slug}`}
                  class="flex items-center justify-between py-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors duration-200 group">
                  <span>{cat.name}</span>
                  <span class="text-xs text-[var(--color-text-subtle)] group-hover:text-[var(--color-primary)]">{cat.postCount}</span>
                </a>
              ))}
            </div>
          </div>
          
          <!-- Tags -->
          <div class="p-6 rounded-subtle border border-[var(--color-border)] bg-[var(--color-surface)]">
            <h3 class="font-serif text-lg font-medium mb-4 text-[var(--color-text)]">热门标签</h3>
            <TagList tags={tags.slice(0, 15)} />
          </div>
        </aside>
      </div>
    </section>
  </div>
  
  <Footer slot="footer" />
  <SearchData slot="footer" />
</BaseLayout>

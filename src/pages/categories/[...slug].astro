---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { filterPublished, sortPosts, mapToBlogPost, getCategories, generateSlug } from '../../utils/content';
import { SITE } from '../../consts';

export const getStaticPaths = (async () => {
  const postsPerPage = 9;
  const posts = await getCollection('posts');
  const published = filterPublished(posts);
  const categories = getCategories(published);
  const validCategories = categories.filter(cat => cat.slug && cat.slug.trim() !== '');

  const paths = [];

  for (const category of validCategories) {
    const categoryPosts = published.filter(post =>
      generateSlug(post.data.category) === category.slug
    );
    const sorted = sortPosts(categoryPosts);
    const totalPages = Math.ceil(sorted.length / postsPerPage);

    // 第 1 页: /categories/xxx
    paths.push({
      params: { slug: category.slug },
      props: { category, postsPerPage, currentPage: 1, totalPages, totalPosts: sorted.length },
    });

    // 第 2+ 页: /categories/xxx/2, /categories/xxx/3 ...
    for (let p = 2; p <= totalPages; p++) {
      paths.push({
        params: { slug: `${category.slug}/${p}` },
        props: { category, postsPerPage, currentPage: p, totalPages, totalPosts: sorted.length },
      });
    }
  }

  return paths;
}) satisfies GetStaticPaths;

const { category, postsPerPage, currentPage, totalPages, totalPosts } = Astro.props;

const posts = await getCollection('posts');
const published = filterPublished(posts);
const categoryPosts = published.filter(post =>
  generateSlug(post.data.category) === category.slug
);
const sorted = sortPosts(categoryPosts);
const displayPosts = sorted.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);

const author = {
  id: '1',
  name: SITE.defaultAuthor,
  slug: 'author',
};

const baseUrl = `/categories/${category.slug}`;
---

<BaseLayout title={currentPage === 1 ? `分类：${category.name}` : `分类：${category.name} - 第 ${currentPage} 页`} description={`${category.name} 分类下的所有文章`} class="pt-16">
  <Navbar slot="header" />

  <div class="container-luxury section-padding pt-24">
    <!-- Category Header -->
    <div class="text-center mb-12 pb-8 border-b border-[var(--color-border)]">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-gentle bg-[var(--color-primary-subtle)] text-[var(--color-primary)] text-sm mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/><path d="M2 10h20"/></svg>
        <span>分类</span>
      </div>
      <h1 class="font-serif text-3xl md:text-4xl font-medium mb-3 text-[var(--color-text)]">{category.name}</h1>
      <p class="text-[var(--color-text-muted)]">该分类下共有 {totalPosts} 篇文章</p>
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayPosts.map((post, index) => (
        <div class="animate-fade-in-up" style={`animation-delay: ${0.05 * index}s;`}>
          <PostCard post={mapToBlogPost(post, author)} />
        </div>
      ))}
    </div>

    {totalPages > 1 && (
      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        baseUrl={baseUrl}
      />
    )}

    <!-- Back to All -->
    <div class="mt-12 text-center">
      <a
        href="/posts"
        class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span>查看所有文章</span>
      </a>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

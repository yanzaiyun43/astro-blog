---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { SITE, SOCIAL_LINKS } from '../consts';
import { getCollection } from 'astro:content';
import { getCategories, getTags } from '../utils/content';

// 获取动态数据
const posts = await getCollection('posts');
const publishedPosts = posts.filter(post => !post.data.draft && post.data.publishedAt <= new Date());
const categories = getCategories(publishedPosts);
const tags = getTags(publishedPosts);

// 计算运行天数（从最早文章发布日期或固定日期）
const startDate = new Date('2025-12-31');
const runDays = Math.floor((new Date().getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));

const skills = ['前端开发', 'Astro', 'TypeScript', 'Tailwind CSS', '极简设计', '技术写作'];
const stats = [
  { label: '文章', value: String(publishedPosts.length) },
  { label: '分类', value: String(categories.length) },
  { label: '标签', value: String(tags.length) },
  { label: '运行天数', value: `${runDays}+` },
];
---

<BaseLayout title="关于" description={`关于 ${SITE.name} 和 ailmel 的介绍`} class="pt-16">
  <Navbar slot="header" />

  <div class="container-luxury section-padding pt-24 max-w-4xl">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="w-24 h-24 mx-auto mb-6 rounded-full overflow-hidden border-2 border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors duration-300">
        <img 
          src="/src/assets/a1.jpg" 
          alt="ailmel 头像"
          class="w-full h-full object-cover"
        />
      </div>
      <h1 class="font-serif text-3xl md:text-4xl font-medium mb-4 text-[var(--color-text)]">关于我</h1>
      <p class="text-[var(--color-text-muted)] max-w-xl mx-auto leading-relaxed">
        我是 ailmel，一个热爱技术与设计的开发者。
      </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-4 gap-4 md:gap-8 mb-16 py-8 border-y border-[var(--color-border)]">
      {stats.map(stat => (
        <div class="text-center">
          <div class="font-serif text-xl md:text-3xl font-medium text-[var(--color-text)] mb-1">{stat.value}</div>
          <div class="text-xs md:text-sm text-[var(--color-text-muted)]">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Bio -->
    <div class="prose max-w-none mb-16">
      <h2 class="font-serif text-2xl font-medium mb-6 text-[var(--color-text)]">关于旧识桥</h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">
        欢迎来到 {SITE.name}，这是我的个人数字花园。
      </p>
      <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">
        "旧识桥"这个名字寓意着连接过去与现在的桥梁。在这里，我记录技术学习的心得、分享设计思考，以及生活中那些值得记录的瞬间。
      </p>
      <p class="text-[var(--color-text-muted)] leading-relaxed">
        我相信好的内容应该像一座桥，连接作者与读者，传递知识与思考。如果你对我的文章有任何想法，欢迎通过下方的社交链接与我交流。
      </p>
    </div>

    <!-- Skills -->
    <div class="mb-16">
      <h2 class="font-serif text-2xl font-medium mb-6 text-[var(--color-text)]">关注领域</h2>
      <div class="flex flex-wrap gap-3">
        {skills.map(skill => (
          <span class="px-4 py-2 text-sm border border-[var(--color-border)] rounded-gentle text-[var(--color-text-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all duration-300">
            {skill}
          </span>
        ))}
      </div>
    </div>

    <!-- Contact -->
    <div class="text-center p-8 border border-[var(--color-border)] rounded-gentle bg-[var(--color-surface-elevated)]">
      <h2 class="font-serif text-xl font-medium mb-4 text-[var(--color-text)]">保持联系</h2>
      <p class="text-[var(--color-text-muted)] text-sm mb-6">关注我的社交媒体，获取最新动态</p>
      <div class="flex items-center justify-center gap-4">
        <a
          href={SOCIAL_LINKS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 flex items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-all duration-300"
          aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a
          href={SOCIAL_LINKS.sitemap}
          class="w-10 h-10 flex items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-all duration-300"
          aria-label="站点地图">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M14 14h7v7h-7z"/><path d="M3 14h7v7H3z"/></svg>
        </a>
        <a
          href={SOCIAL_LINKS.email}
          class="w-10 h-10 flex items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-all duration-300"
          aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a
          href={SOCIAL_LINKS.rss}
          class="w-10 h-10 flex items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-all duration-300"
          aria-label="RSS">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        </a>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

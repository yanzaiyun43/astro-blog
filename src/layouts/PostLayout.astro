---
import BaseLayout from './BaseLayout.astro';
import type { BlogPost } from '../types';
import { formatDate, estimateReadingTime, countWords } from '../utils/content';
import Giscus from '../components/Giscus.astro';
import { SITE } from '../consts';

interface Props {
  post: BlogPost;
  headings?: { depth: number; slug: string; text: string }[];
  relatedPosts?: BlogPost[];
}

const { post, headings = [], relatedPosts = [] } = Astro.props;

const readingTime = estimateReadingTime(post.content);
const wordCount = countWords(post.content);
const hasToc = headings.filter(h => h.depth <= 3).length > 0;

// 构建 Article Schema
const articleSchema = {
  '@type': 'Article' as const,
  headline: post.title,
  description: post.description,
  url: `${SITE.url}/posts/${post.slug}`,
  datePublished: post.publishedAt.toISOString(),
  dateModified: post.updatedAt?.toISOString() || post.publishedAt.toISOString(),
  author: {
    '@type': 'Person' as const,
    name: post.author.name,
  },
  publisher: {
    '@type': 'Person' as const,
    name: SITE.defaultAuthor,
  },
  image: post.cover?.src ? `${SITE.url}${post.cover.src}` : undefined,
  keywords: post.tags.map(t => t.name),
  articleSection: post.category?.name,
};

// 构建 BreadcrumbList Schema
const breadcrumbSchema = {
  '@type': 'BreadcrumbList' as const,
  itemListElement: [
    {
      '@type': 'ListItem' as const,
      position: 1,
      name: '首页',
      item: SITE.url,
    },
    {
      '@type': 'ListItem' as const,
      position: 2,
      name: post.title,
      item: `${SITE.url}/posts/${post.slug}`,
    },
  ],
};
---

<BaseLayout 
  title={post.title} 
  description={post.description}
  image={post.cover?.src}
  type="article"
  publishDate={post.publishedAt}
  modifiedDate={post.updatedAt}
  tags={post.tags.map(t => t.name)}
  class="w-full pt-16"
  jsonLdSchema={[articleSchema, breadcrumbSchema]}
>
  <div slot="header">
    <slot name="header" />
  </div>
  
  <article class="w-full">
    <!-- Header -->
    <header class="w-full border-b border-[var(--color-border)]">
      <div class="container-luxury section-padding">
        <div class="max-w-3xl mx-auto text-center">
          <div class="flex items-center justify-center gap-3 text-sm text-[var(--color-text-subtle)] mb-4 tracking-wide">
            <time datetime={post.publishedAt.toISOString()} class="font-medium">{formatDate(post.publishedAt)}</time>
            <span class="w-1 h-1 rounded-full bg-[var(--color-text-subtle)] opacity-50"></span>
            <span>{readingTime} 分钟阅读</span>
            <span class="w-1 h-1 rounded-full bg-[var(--color-text-subtle)] opacity-50"></span>
            <span>{wordCount} 字</span>
          </div>
          
          <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-medium mb-4 leading-tight text-balance">
            {post.title}
          </h1>
          
          <p class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl mx-auto text-balance">
            {post.description}
          </p>
          
          {post.tags.length > 0 && (
            <div class="flex items-center justify-center gap-2 mt-6 flex-wrap">
              {post.tags.map(tag => (
                <a 
                  href={`/tags/${tag.slug}`}
                  class="inline-flex items-center px-3 py-1.5 text-xs leading-none tracking-wide border border-[var(--color-border)] rounded-md text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] hover:bg-[var(--color-primary-subtle)] transition-all duration-200 whitespace-nowrap">
                  {tag.name}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>
    
    <!-- Body -->
    <div class="container-luxury py-12 md:py-16">
      <div class="flex gap-12">
        <div class="flex-1 max-w-3xl mx-auto">
          <!-- 手机版目录 -->
          {hasToc && (
            <div class="lg:hidden mb-8" x-data="{ open: false }">
              <button 
                @click="open = !open"
                class="w-full flex items-center justify-between px-4 py-3 border border-[var(--color-border-subtle)] rounded-gentle bg-[var(--color-surface-elevated)] hover:border-[var(--color-primary)] hover:bg-[var(--color-surface)] transition-all duration-200">
                <span class="flex items-center gap-2 text-sm font-medium text-[var(--color-text-muted)]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-text-subtle)]"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
                  目录
                </span>
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  width="16" 
                  height="16" 
                  viewBox="0 0 24 24" 
                  fill="none" 
                  stroke="currentColor" 
                  stroke-width="1.5" 
                  stroke-linecap="round" 
                  stroke-linejoin="round"
                  :class="{ 'rotate-180': open }"
                  class="transition-transform duration-200 text-[var(--color-text-subtle)]">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </button>
              <div 
                x-show="open" 
                x-collapse
                class="mt-2 p-4 border border-[var(--color-border-subtle)] rounded-gentle bg-[var(--color-surface-elevated)] max-h-64 overflow-y-auto scrollbar-thin">
                <nav class="space-y-2">
                  {headings.filter(h => h.depth <= 3).map(heading => (
                    <a 
                      href={`#${heading.slug}`}
                      @click.prevent={`open = false; setTimeout(() => { const el = document.getElementById('${heading.slug}'); const y = el.getBoundingClientRect().top + window.pageYOffset - 70; window.scrollTo({ top: y, behavior: 'smooth' }); }, 100)`}
                      class={`block text-sm transition-colors duration-200 ${heading.depth === 2 ? 'text-[var(--color-text-muted)] hover:text-[var(--color-primary)]' : 'text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] pl-4'}`}>
                      {heading.text}
                    </a>
                  ))}
                </nav>
              </div>
            </div>
          )}
          
          <div class="prose prose-lg prose-custom mx-auto">
            <slot />
          </div>
          
          <!-- Article Footer -->
          <footer class="mt-12 pt-8 border-t border-[var(--color-border)]" x-data="{ copied: false }">
            <div class="flex items-center justify-between flex-wrap gap-4">
              <div class="flex items-center gap-3">
                {post.author.avatar && (
                  <img src={post.author.avatar.src} alt={post.author.name} class="w-10 h-10 rounded-full object-cover border border-[var(--color-border)]" />
                )}
                <div>
                  <p class="text-sm font-medium text-[var(--color-text)]">{SITE.name}</p>
                  <!-- 版权声明 -->
                  <p class="text-xs text-[var(--color-text-subtle)] mt-0.5">
                    本文采用 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">CC BY-NC-SA 4.0</a> 许可协议，转载请注明出处
                  </p>
                  <p class="text-xs text-[var(--color-text-subtle)] opacity-70">
                    {post.updatedAt ? `更新于 ${formatDate(post.updatedAt)}` : `发布于 ${formatDate(post.publishedAt)}`}
                  </p>
                </div>
              </div>
              
              <div class="flex items-center gap-2">
                <a 
                  href="/rss.xml"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-3 py-1.5 text-sm text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] transition-colors duration-200 rounded-md hover:bg-[var(--color-surface-elevated)] border border-[var(--color-border)] hover:border-[var(--color-primary)]"
                  title="订阅 RSS">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
                  <span>订阅RSS</span>
                </a>
                <button 
                  @click="navigator.clipboard.writeText(window.location.origin + window.location.pathname).then(() => { copied = true; setTimeout(() => copied = false, 2000); })"
                  class="flex items-center gap-1.5 px-3 py-1.5 text-sm text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] transition-colors duration-200 rounded-md hover:bg-[var(--color-surface-elevated)] border border-[var(--color-border)] hover:border-[var(--color-primary)]"
                  title="复制链接">
                  <svg x-show="!copied" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                  <svg x-show="copied" x-cloak xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-primary)]"><path d="M20 6 9 17l-5-5"/></svg>
                  <span x-text="copied ? '已复制' : '复制链接'"></span>
                </button>
              </div>
            </div>
          </footer>
          
          <!-- Giscus Comments -->
          <Giscus slug={post.slug} title={post.title} />
          
          <!-- Prev/Next Slot -->
          <slot name="article-footer" />
        </div>
        
        <!-- TOC -->
        {hasToc && (
          <aside class="hidden lg:block w-64 shrink-0">
            <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto scrollbar-thin">
              <h3 class="text-xs font-medium uppercase tracking-wider text-[var(--color-text-subtle)] mb-4">目录</h3>
              <nav class="space-y-1 border-l border-[var(--color-border)]">
                {headings.filter(h => h.depth <= 3).map(heading => (
                  <a 
                    href={`#${heading.slug}`}
                    class={`block text-sm py-1 border-l-2 -ml-px pl-4 transition-all duration-200 ${heading.depth === 2 ? 'border-transparent text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]' : 'border-transparent text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] pl-6'}`}>
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}
      </div>
    </div>
    
    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="border-t border-[var(--color-border)] bg-[var(--color-surface-elevated)]">
        <div class="container-luxury section-padding">
          <h2 class="font-serif text-2xl font-medium mb-8 text-center">相关文章</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map(related => (
              <article class="group">
                <a href={`/posts/${related.slug}`} class="block">
                  {related.cover && (
                    <div class="aspect-[16/10] overflow-hidden rounded-lg mb-4 border border-[var(--color-border)]">
                      <img src={related.cover.src} alt={related.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
                    </div>
                  )}
                  <h3 class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors duration-200 line-clamp-2 text-balance">{related.title}</h3>
                  <p class="text-sm text-[var(--color-text-subtle)] mt-2">{formatDate(related.publishedAt)}</p>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
  
  <div slot="footer">
    <slot name="footer" />
  </div>
</BaseLayout>

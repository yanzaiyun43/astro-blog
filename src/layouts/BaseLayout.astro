---
import '../styles/global.css';
import { SITE } from '../consts';
import SEO from '../components/SEO.astro';
import SearchData from '../components/SearchData.astro';
import JsonLd from '../components/JsonLd.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  modifiedDate?: Date;
  tags?: string[];
  class?: string;
  jsonLdSchema?: any;
}

const { 
  title = SITE.title, 
  description = SITE.description,
  image,
  type = 'website',
  publishDate,
  modifiedDate,
  tags,
  class: className = '',
  jsonLdSchema
} = Astro.props;

// 默认 WebSite Schema
const defaultWebSiteSchema = {
  '@type': 'WebSite' as const,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  author: {
    '@type': 'Person' as const,
    name: SITE.defaultAuthor,
  },
};

// 合并 schema
const finalSchema = jsonLdSchema 
  ? (Array.isArray(jsonLdSchema) ? [defaultWebSiteSchema, ...jsonLdSchema] : [defaultWebSiteSchema, jsonLdSchema])
  : defaultWebSiteSchema;
---

<!DOCTYPE html>
<html lang={SITE.language} class="scroll-smooth">
  <head>
    <SEO 
      title={title} 
      description={description} 
      image={image}
      type={type}
      publishDate={publishDate}
      modifiedDate={modifiedDate}
      tags={tags}
    />
    
    <!-- JSON-LD Structured Data -->
    <JsonLd schema={finalSchema} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;500;600&family=Noto+Serif+SC:wght@400;500;600&display=swap" rel="stylesheet" />
    
    <!-- KaTeX CSS for math formulas -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous" />
    
    <!-- Search Data -->
    <SearchData />
    
    <!-- Code copy buttons -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // 为所有表格添加滚动容器
        const tables = document.querySelectorAll('.prose table');
        tables.forEach(function(table) {
          // 如果表格已经在 table-wrapper 中，跳过
          if (table.parentElement?.classList.contains('table-wrapper')) return;
          
          const wrapper = document.createElement('div');
          wrapper.className = 'table-wrapper';
          table.parentNode.insertBefore(wrapper, table);
          wrapper.appendChild(table);
        });
        
        // 为所有代码块添加复制按钮
        const codeBlocks = document.querySelectorAll('pre');
        codeBlocks.forEach(function(pre) {
          // 创建复制按钮容器
          const wrapper = document.createElement('div');
          wrapper.className = 'code-copy-wrapper absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300';
          wrapper.innerHTML = '<button class="code-copy-btn w-16 p-1.5 rounded-subtle bg-[var(--color-surface)]/90 backdrop-blur-sm border border-[var(--color-border)] text-[var(--color-text-subtle)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-all duration-300 flex items-center justify-center" aria-label="复制代码"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg></button>';
          

          
          // 确保 pre 有 relative 和 group 类
          pre.classList.add('relative', 'group');
          pre.appendChild(wrapper);
          
          // 绑定复制事件
          const btn = wrapper.querySelector('.code-copy-btn');
          btn.addEventListener('click', function() {
            const code = pre.querySelector('code')?.textContent || '';
            navigator.clipboard.writeText(code).then(function() {
              // 改变按钮为文字提示
              const originalContent = btn.innerHTML;
              btn.innerHTML = '<span class="text-xs font-medium px-1 whitespace-nowrap">复制成功</span>';
              btn.classList.add('!text-[var(--color-primary)]', '!border-[var(--color-primary)]');
              
              // 2秒后恢复
              setTimeout(function() {
                btn.innerHTML = originalContent;
                btn.classList.remove('!text-[var(--color-primary)]', '!border-[var(--color-primary)]');
              }, 2000);
            });
          });
        });
      });
    </script>
  </head>
  
  <body class="antialiased min-h-screen flex flex-col bg-[var(--color-bg)] text-[var(--color-text)] transition-colors duration-300 selection:bg-[var(--color-primary-muted)] selection:text-[var(--color-text)]">
    <div class="page-wrapper flex-1 flex flex-col">
      <slot name="header" />
      
      <main class={className}>
        <slot />
      </main>
      
      <slot name="footer" />
    </div>
    
    <!-- Back to top -->
    <div x-data="{ visible: false }" 
         x-show="visible" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-2"
         @scroll.window.throttle.100ms="visible = window.pageYOffset > 300"
         class="fixed bottom-6 right-6 z-50 md:bottom-8 md:right-8">
      <button 
        @click="window.scrollTo({ top: 0, behavior: 'smooth' })"
        class="w-10 h-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] hover:shadow-luxury-hover transition-all duration-300 flex items-center justify-center"
        aria-label="返回顶部">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
      </button>
    </div>
  </body>
</html>
